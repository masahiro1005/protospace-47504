<div class="main">
  <div class="inner">
    <div class="form__wrapper">
    <h2 class="page-heading">ユーザー新規登録</h2>

<%= form_with model: resource, url: registration_path(resource_name), local: true do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>



  <div class="field">
    <%= f.label :email, "メールアドレス" %><br />
    <%= f.email_field :email, id: "user_email" %>
  </div>

  <div class="field">
    <p><%= f.label :password, "パスワード（6文字以上）" %></p>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation, "パスワード再入力" %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div> 

  <div class="field">
    <p><%= f.label :name, "ユーザー名" %></p>
    <p><%= f.text_field :name %></p>
  </div>

  <div class="field">
    <p><%= f.label :profile, "プロフィール" %></p>
    <p><%= f.text_area :profile, class: :form__text %></p>
  </div>

  <div class="field">
    <p><%= f.label :occupation, "所属" %></p>
    <p><%= f.text_area :occupation, class: :form__text %></p>
  </div>

  <div class="field">
    <p><%= f.label :position, "役職" %></p>
    <p><%= f.text_area :position, class: :form__text %></p>
  </div>
  



  <div class="actions">
    <%= f.submit "新規登録", class: :form__btn %>
  </div>
<% end %>


    </div>
  </div>
</div>